{
    "name": "eteacher/invicta-admin",
    "description": "Admin Panel for Laravel projects",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Eteacher\\InvictaAdmin\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Eteacher\\InvictaAdmin\\Tests\\": "tests"
        }
    },
    "authors": [
        {
            "name": "Ilya Gromov",
            "email": "ilyag@eteachergroup.com"
        }
    ],
    "require": {
        "inertiajs/inertia-laravel": "^0.6.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Eteacher\\InvictaAdmin\\InvictaServiceProvider"
            ],
            "aliases": {
                "InvictaAdmin": "Eteacher\\InvictaAdmin\\InvictaAdmin"
            }
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.8",
        "phpro/grumphp": "^1.12",
        "phpunit/phpunit": "^9.5",
        "orchestra/testbench": "^7.0"
    },
    "config": {
        "allow-plugins": {
            "phpro/grumphp": true
        }
    },
    "scripts": {
        "check-style": "php-cs-fixer fix --dry-run --diff",
        "fix-style": "php-cs-fixer fix",
        "test": "vendor/bin/phpunit",
        "test-f": "vendor/bin/phpunit --filter"
    }
}

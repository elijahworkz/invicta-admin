{
  "compilerOptions": {
      "target": "esnext",
      "module": "esnext",
      "moduleResolution": "node",
      "useDefineForClassFields": true,
      "strict": true,
      "sourceMap": true,
      "resolveJsonModule": true,
      "isolatedModules": true,
      "esModuleInterop": true,
      "lib": ["esnext", "dom"],
      "paths": {
        "@/*": [
          "./resources/js/*"
        ]
      },
      "plugins": [
          {
              "name": "@vuedx/typescript-plugin-vue"
          }
      ],
      "allowJs": true,
      "types": ["element-plus/global"],
      "jsx": "preserve"
  },
  "include": [
      "resources/js/**/*.ts",
      "resources/js/**/*.d.ts",
      "resources/js/**/*.vue"
  ],
  "exclude": ["node_modules", "public"]
}